venv/
__pycache__/
*.pyc

# 데이터: 모두 다운로드 스크립트로 받음 (용량 큼)
data/raw/
data/processed/

# 학습 체크포인트는 LFS 또는 직접 push (각 25-100MB)
# .gitignore 에서 풀고 git add -f 로 명시적으로 포함

# 학습 로그: 실행 중 생성
logs/*
!logs/.gitkeep

# 추론 결과: PNG 들은 너무 커서 제외, metrics.txt 와 summary.csv 만 포함
results/**/*.png
results/**/*.jpg
results/**/*.jpeg
!results/.gitkeep

# 이전 버전 결과 (현재 활성 버전만 push). 로컬에는 유지하되 git tracked 안 함.
results/test_full_v1/
results/test_full_v2/
results/test_full_v3/
results/test_full_v4_brainonly_backup/

.DS_Store
.vscode/
.claude/
